<div class="topili">

<!-- BEGIN topics_list_box -->
<!-- BEGIN row -->

<!-- BEGIN header_table -->  
<div class="tlist-a">
<i class="fi fi-rr-megaphone-sound-waves"></i>   
<h1>
{topics_list_box.row.L_TITLE}
</h1>
</div>
<!-- END header_table -->
  
<!-- BEGIN topic -->    

<!-- BEGIN table_sticky -->  
<div class="tlist-t">
<i class="fi fi-rr-file-edit"></i>   
<h1>
{topics_list_box.row.topic.table_sticky.L_TITLE}
</h1>
</div>
<!-- END table_sticky -->
  

<div class="tema {topics_list_box.row.ROW_ALT_CLASS}">
  
<div class="satus" style="background-image:url('{topics_list_box.row.TOPIC_FOLDER_IMG}');"></div>
  
<div class="topic" title="{topics_list_box.row.L_TOPIC_FOLDER_ALT}" {topics_list_box.row.ICON}>
  
<!-- BEGIN single_selection -->
<input type="radio" name="{topics_list_box.FIELDNAME}" value="{topics_list_box.row.FID}" {topics_list_box.row.L_SELECT} />
<!-- END single_selection -->
  
<div class="toptt">  
  <dfn>{topics_list_box.row.TOPIC_TYPE}</dfn>

<a class="topictitle" href="{topics_list_box.row.U_VIEW_TOPIC}">
{topics_list_box.row.TOPIC_TITLE}
</a>
</div>
  
<div class="autfe">
<span>
{topics_list_box.row.LAST_POST_AUTHOR}
<dfn>{topics_list_box.row.LAST_POST_TIME}</dfn>
</span>
{topics_list_box.row.GOTO_PAGE_NEW}

<!-- BEGIN nav_tree -->
{topics_list_box.row.TOPIC_NAV_TREE_NEW}
<!-- END nav_tree -->  
</div>
</div>
 
<div class="pyv">  
<div class="posts">{topics_list_box.row.REPLIES} <dfn><i class="fi fi-rr-auto-reply"></i></dfn></div>
<div class="views">{topics_list_box.row.VIEWS} <dfn><i class="fi fi-rr-eye"></i></dfn></div>
</div>  
  
<div class="lastpost">
<!-- BEGIN avatar -->
<div class="avalist">{topics_list_box.row.topic.avatar.LAST_POST_AVATAR}</div>
<!-- END avatar -->
</div>
<!-- BEGIN multi_selection -->
<input onclick="javascript:check_uncheck_main_{topics_list_box.row.BOX_ID}();" type="checkbox" name="{topics_list_box.FIELDNAME}[]{topics_list_box.row.BOX_ID}" value="{topics_list_box.row.FID}" {topics_list_box.row.L_SELECT} />
<!-- END multi_selection -->
  
<div class="desul">  
<div class="descp">  
<!-- BEGIN switch_description -->
{topics_list_box.row.topic.switch_description.TOPIC_DESCRIPTION}
<!-- END switch_description -->  
</div>    
<div class="ultem">
<span>{topics_list_box.row.LAST_POST_AUTHOR}
<dfn>{L_LASTPOST}</dfn>
{topics_list_box.row.LAST_POST_IMG}
{topics_list_box.row.LAST_POST_TIME}
</span>
</div>
</div>  

  </div>
  
<!-- END topic -->  
  


<!-- END row -->
<!-- END topics_list_box -->

</div>  
  
<style>
.topili {
  display: grid;
  gap: 14px; 
}  
  
.tlist-a, .tlist-t {
    background: var(--color-5);
    padding: 10px;
    border-radius: 0.38em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--color-3);
    flex-flow: row-reverse;
    font-family: var(--titulos);
    font-size: 2em;
}
  
.tlist-a i, .tlist-t i {
  margin: 10px;
  transition: all 0.3s ease;
}
  
.tlist-a:hover i,
.tlist-t:hover i {
  transform: translateY(-4px);
}

.tlist-a:hover i:active,
.tlist-t:hover i:active {
  transform: translateY(0);
}
  
.tlist-a h1, .tlist-t h1{
  margin: 0;
}  
  
.tema {
    background: var(--color-5);
    display: grid;
    grid-template-columns: 40px minmax(200px, 2fr) 70px 80px 200px;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border-radius: 0.38em;
    overflow: hidden;
    transition: all 0.25s ease;
    color: var(--color-6);
}
  
.tema:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 0px var(--tcolor3);
} 
  
.satus {
  width: 40px;
  height: 40px;
  background-size: cover;
  border-radius: 8px;
}

.topic {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
  
.topictitle {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}  

.posts, .views {
  text-align: center;
}

.lastpost {
    display: flex;
    justify-content: center;
    width: 80px;
    height: 80px;
    overflow: hidden;
} 
  
.descp {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200px;
}  
</style>  
