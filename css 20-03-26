/*CUSTOM SCROLL BAR*/
/* Works on Firefox */
* {
    scrollbar-width: thin;
    scrollbar-color: var(--color-3) var(--color-1);
}

/* Works on Chrome, Edge, and Safari */
*::-webkit-scrollbar {
  width: 10px;
}

*::-webkit-scrollbar-track {
  background: var(--color-1);
}

*::-webkit-scrollbar-thumb {
  background-color: var(--color-3);
  border-radius: 20px;
