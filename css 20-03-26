/*SWITCHEROO*/

.multismultis {
    position: absolute;
    top: 150px;
    right: 0px;
    left: auto;
    width: min(95vw, 500px);
     max-width: calc(100vw - 20px);
       box-sizing: border-box;
    background: var(--color-4);
    border: 1px solid var(--color-3);
    border-radius: 15px;
    padding: 15px;
    z-index: 999;
    display: block;
    visibility: hidden;
    opacity: 0;
    transform: translateY(-20px);
    transition: opacity 0.4s ease, transform 0.4s ease, visibility 0.4s;
    pointer-events: none;
}

.multismultis.abirrr {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    z-index: 999999 !important; 
    pointer-events: auto;     
}

.multis-header {
    padding: 20px;
    border-bottom: 1px solid var(--color-3);
    text-align: center;
    width: -webkit-fill-available;
    height: -webkit-fill-available;
    margin: 0 0 22px 0;
}

.multis-header h1 {
    margin: 0;
    text-transform: uppercase;
    font-size: 1.2em;
    font-weight: 800;
    letter-spacing: 1px;
    color: var(--color-3);
}

.multismultis .switcheroo__squircles {
    position: static !important;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    justify-content: center;
    justify-items: center;
    padding: 0;
    list-style: none;

}

.switcheroo__squircle {
    width: 150px;
    height: stretch;
    background: var(--color-1);
    border-radius: 7px;
    padding: 10px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-flow: column;
    line-height: 1em;
}

.switcheroo__squircle:last-child, .switcheroo__squircle:last-child .switcheroo__popper-text {
    background: var(--color-3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-4);
    font-size: 0.9em;
    font-family: var(--cuerpo1);
    text-transform: uppercase;
    font-weight: 600;
    line-height: 1em;
    cursor: pointer;
    box-shadow: none;
}


.switcheroo__avatar {
    width: 130px;
    height: 60px;
    overflow: hidden;
    border-radius: 10px;
    cursor: pointer;
    box-shadow: 0 0 6px var(--color-2);
}

.switcheroo__avatar img {
    max-width: 300px;
    max-height: 500px;
    width: 145px;
    height: 200px;
    margin: -10px 0 0 0px;
    object-fit: cover;
}

.switcheroo__squircle.active .switcheroo__avatar {
    box-shadow: 0 0 10px var(--color-3);
}



.switcheroo__delete {
    position: absolute;
    top: 0px;
    right: 0px;
    margin: 0;
    cursor: pointer;
    background: var(--color-2);
    width: 25px;
    height: 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    color: var(--color-4);
}

.switcheroo__popper {
