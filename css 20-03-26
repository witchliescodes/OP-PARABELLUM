    width: 30px;
    height: 30px;
    border-radius: 10px;
    border: none;
    background-color: var(--color-2) !important;
    color: var(--color-5);
    font-size: 1em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.labels button:hover {
  color: var(--color-3);
