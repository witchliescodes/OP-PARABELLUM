/*NOTIFICACIONES FLOTANTES*/

#fa_toolbar {
    position: absolute !important;
    margin: -73px 0 0 0;
}

#fa_notifications {
    position: fixed !important;
    top: 20px !important;
    right: 20px !important;
    z-index: 9999 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background-color: var(--color-2, var(--color-1)) !important;
    border-radius: 5px !important;
    box-shadow: 0 4px 12px var(--color-2) !important;
    transition: all 0.3s ease !important;
    text-decoration: none;
}

#fa_notifications::before {
    content: "\f0f3" !important;
    font-family: "FontAwesome" !important;
    font-size: 1em !important;
    color: var(--color-5) !important;
    line-height: 1 !important;
    margin: 0 10px 0 4px;
}


#fa_notifications:hover {
    background-color: var(--color-3) !important;
    transform: scale(1.1) !important;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3) !important;
    text-decoration: none!important;
}

#fa_toolbar #fa_right #fa_notifications.unread #notif_unread {
    display: inline;
    background: var(--color-3);
    padding: 1px;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    font-size: 0.8em;
}


/* Ocultar por defecto */
#fa_notifications {
    display: none !important;
}

/* Mostrar solo cuando hay notificaciones */
#fa_notifications.unread,
#fa_notifications:has(#notif_unread:not(:empty)) {
    display: flex !important; /* o block, según tu diseño */
}

/* También mostrar si el texto no es "(0)" */
#fa_notifications:has(#notif_unread) {
    display: none !important;
}

#fa_notifications:has(#notif_unread:not(:contains("(0)"))) {
    display: flex !important;
}

/* ===== ESTILOS PARA EL DROPDOWN ===== */
#notif_list {
    position: fixed !important;
    top: 90px !important;
    right: 20px !important;
    left: auto !important;
    width: 350px !important;
    max-width: 90vw !important;
    background: var(--color-5) !important;
    border: 0px solid !important;
    border-radius: 10px !important;
    box-shadow: 0 0px 15px var(--color-3) !important;
    padding: 0 !important;
    list-style: none !important;
    z-index: 10000 !important;
}

#notif_list::before {
    content: "Notificaciones" !important;
    display: block !important;
    padding: 15px 20px !important;
    background: linear-gradient(135deg, var(--color-5), var(--color-3, #e9ecef)) !important;
    font-size: 16px !important;
    font-weight: 600 !important;
    color: var(--color-3);
    border-radius: 12px 12px 0 0 !important;
}

.oscuro #notif_list::before {
    background: linear-gradient(135deg, var(--color-5), var(--color-3, #e9ecef)) !important;
    color: var(--color-3);
}

 #notif_list li {
    font-size: 1em!important;
    color: var(--color-1)!important;
    line-height: 1.2em!important;
    display: flex !important;
    align-items: center;
    justify-content: flex-start;
    border-top: none;
    background: var(--color-6)!important;
}

#notif_list li.unread { 
    font-weight: 500!important;
    background-color: var(--color-2)!important;
    color: var(--color-6)!important;
}
#notif_list li.unread .contentText a { 
    font-weight: 500!important;
    background-color: var(--color-1)!important;
    color: var(--color-6)!important;
  font-weight: 800 !important;
}

#fa_toolbar #fa_right #notif_list li .contentText a {
    color: var(--color-3) !important;
    text-decoration: none !important;
    vertical-align: baseline;
    font-weight: 800 !important;
}

/* Items de notificaciones */
.oscuro #notif_list {
    background-color: var(--fondo2);
    box-shadow: 15px 15px 15px -10px var(--fondo1);
}

#notif_list li .content {
    width: -webkit-fill-available !important;
    margin: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    overflow: hidden !important;
    vertical-align: top !important;
    color: var(--color-1) !important;
    line-height: inherit !important;
}

#notif_list li .contentText {
    float: left;
    width: -webkit-fill-available;
    height: max-content;
    overflow: hidden;
    color: var(--tfon2);
    font-family: var(--tt2);
}

.oscuro #notif_list li .contentText {
   color: var(--texto);
}

.contentText a {
    color: var(--acento3) !important;
    text-decoration: none !important;
    vertical-align: baseline;
    font-weight: 800;
}

#notif_list .content .delete {
    background-image: none !important;  
    position: relative;
}

#notif_list .content .delete::before {
    content: "\f2ed";
    font-family: "Font Awesome 6 Free";
    font-weight: 900;
    font-size: 1.4em;
    color: var(--color-3);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  transition: 400ms ease-in-out;
}

#notif_list .content .delete:hover::before {
    color: var(--bs-red);        
    transform: translate(-50%, -50%) scale(1.1);
    cursor: pointer;
}

/* Item "Ver todas" */
#notif_list li.see_all {
    text-align: center !important;
    background-color: #f8f9fa !important;
    border-radius: 0 0 12px 12px !important;
}

#notif_list li.see_all a {
    color: var(--acento3, #007bff) !important;
    text-decoration: none !important;
    font-weight: 500 !important;
}

/* Responsive */
@media (max-width: 768px) {
    #fa_notifications {
        top: 10px !important;
        right: 10px !important;
        width: 48px !important;
        height: 48px !important;
    }
    
    #fa_notifications::before {
        font-size: 20px !important;
    }
    
    #notif_list {
        top: 70px !important;
        right: 10px !important;
        width: 300px !important;
    }
}

/* Ocultamos el left dinámico que pone Foroactivo */
#notif_list[style*="left"] {
    left: auto !important;
    right: 20px !important;
}

/*NUEVOS MENSAJES PRIVADOS*/

.oscruro .oppmsj[data-new-mps] {
    filter: drop-shadow(0px 0px 6px var(--color-2));
    position: relative;
}
.claro .oppmsj[data-new-mps] {
    filter: drop-shadow(0px 0px 2px var(--color-3));
    position: relative;
}

.oppmsj[data-new-mps] i {
    font-family: 'bootstrap-icons', sans-serif; 
    &::before {
        content: "\F691";
    }
    animation: campanita 3s ease-in-out infinite;
    display: inline-block;
    transform-origin: top center; 
}

.oppmsj[data-new-mps]::before {
    content: var(--mensajes);
    position: absolute;
    margin: -18px 0 0 25px;
    background-color: var(--color-2);
    color: var(--color-5);
    font-size: 11px;
    padding: 2px 5px;
    border-radius: 21%;
    line-height: 1;
    z-index: 10;
}

@keyframes campanita {
    0% {
        transform: rotate(0deg);
    }
    5% {
        transform: rotate(12deg); /* Un pequeño balanceo a la derecha */
    }
    10% {
        transform: rotate(-8deg); /* Luego a la izquierda, pero un poco menos */
    }
    15% {
        transform: rotate(4deg);  /* Otro pequeño ajuste */
    }
    20% {
        transform: rotate(0deg);  /* Vuelve a su posición original */
    }
    100% {
        transform: rotate(0deg);  /* Se queda quieto hasta que el ciclo se repite */
    }
}
.oppmensaj { display: none;}

/*FIN NUEVOS MENSAJES PRIVADOS*/

