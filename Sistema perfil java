// RADIO RETRO POR PERFIL
// =========================

function crearRadioRetro() {

  const contenedor = document.querySelector(".music .valor");
  if (!contenedor) return;

  let contenido = contenedor.innerHTML.trim();

  if (!contenido || contenido === "-") return;

  // Convertir <br> a líneas
  let lineas = contenido
    .replace(/<br\s*\/?>/gi, "\n")
    .split("\n")
    .map(l => l.trim())
    .filter(l => l.length > 0)
    .slice(0, 3); // máximo 3 canciones

  // Parsear canciones
  let lista = lineas.map((linea, i) => {

    let partes = linea.split("|");

    return {
      titulo: partes[0]?.trim() || `Track ${i+1}`,
      url: partes[1]?.trim() || partes[0]?.trim()
    };

  }).filter(c => c.url);

  if (!lista.length) return;

  // Limpiar contenido original
  contenedor.innerHTML = "";

  // Crear radio
  const radio = document.createElement("div");
  radio.className = "radio-retro";

  radio.innerHTML = `
    <div class="radio-screen">ON AIR ●</div>
    <div class="radio-title">${lista[0].titulo}</div>
    <div class="radio-controls">
      <button class="play">▶</button>
      <button class="next">⏭</button>
    </div>
    <audio preload="none"></audio>
  `;

  contenedor.appendChild(radio);

  const audio = radio.querySelector("audio");
  const titulo = radio.querySelector(".radio-title");
  const playBtn = radio.querySelector(".play");
  const nextBtn = radio.querySelector(".next");

  let actual = 0;

  function cargar(i) {
    audio.src = lista[i].url;
    titulo.textContent = lista[i].titulo;
  }

  cargar(0);

  playBtn.onclick = function() {
    if (audio.paused) {
      audio.play();
      playBtn.textContent = "⏸";
    } else {
      audio.pause();
      playBtn.textContent = "▶";
    }
  };

  nextBtn.onclick = function() {
    actual++;
    if (actual >= lista.length) actual = 0;
    cargar(actual);
    audio.play();
    playBtn.textContent = "⏸";
  };

  audio.onended = function() {
    actual++;
    if (actual >= lista.length) actual = 0;
    cargar(actual);
    audio.play();
  };

}

// Ejecutar
crearRadioRetro();

});
